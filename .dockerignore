# ── Зависимости ──────────────────────────────────────────────────────────────
**/node_modules

# ── Артефакты сборки ─────────────────────────────────────────────────────────
**/dist
**/.next
**/build
**/.turbo

# ── Git ───────────────────────────────────────────────────────────────────────
**/.git
**/.gitignore
**/.gitattributes

# ── Логи и runtime мусор ──────────────────────────────────────────────────────
**/*.log
**/npm-debug.log*
**/pnpm-debug.log*
**/.pnpm-store

# ── IDE и OS ──────────────────────────────────────────────────────────────────
**/.vscode
**/.idea
**/.DS_Store
**/Thumbs.db

# ── Тесты ────────────────────────────────────────────────────────────────────
**/test
**/tests
**/__tests__
**/*.spec.ts
**/*.test.ts
**/coverage
**/.nyc_output

# ── Env-файлы (секреты не должны попадать в image) ───────────────────────────
**/.env
**/.env.*
!**/.env.example

# ── Docker-файлы самого проекта ───────────────────────────────────────────────
**/docker-compose*.yml
**/Dockerfile*

# ── Документация ─────────────────────────────────────────────────────────────
**/README.md
**/CHANGELOG.md
**/*.md
