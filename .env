# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme
POSTGRES_DB=app_db
POSTGRES_PORT=5432

# ── Prisma ────────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:changeme@postgres:5432/app_db

# ── Backend ───────────────────────────────────────────────────────────────────
NODE_ENV=development
BACKEND_PORT=3000

# ── Auth (JWT) ────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=changeme
JWT_REFRESH_SECRET=changeme
